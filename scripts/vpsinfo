#!/usr/bin/env bash

# vpsinfo - small Ubuntu/Debian VPS status viewer.
# The script only reads local runtime information and never changes system state.

export LC_ALL=C

UNKNOWN="未知"

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

value_or_unknown() {
    local value="${1:-}"
    if [ -n "$value" ]; then
        printf '%s' "$value"
    else
        printf '%s' "$UNKNOWN"
    fi
}

print_kv() {
    local label="$1"
    local value="${2:-$UNKNOWN}"
    printf "%s : %s\n" "$label" "$value"
}

calc_percent() {
    local used="${1:-0}"
    local total="${2:-0}"
    awk -v used="$used" -v total="$total" 'BEGIN {
        if (total > 0) {
            printf "%.1f%%", used * 100 / total
        } else {
            printf "0%%"
        }
    }'
}

get_hostname() {
    local value=""
    if command_exists hostnamectl; then
        value="$(hostnamectl --static 2>/dev/null || true)"
    fi
    if [ -z "$value" ]; then
        value="$(uname -n 2>/dev/null || true)"
    fi
    value_or_unknown "$value"
}

get_os_version() {
    local value=""
    if [ -r /etc/os-release ]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        value="${PRETTY_NAME:-${NAME:-} ${VERSION:-}}"
    fi
    if [ -z "$value" ] && command_exists hostnamectl; then
        value="$(hostnamectl 2>/dev/null | awk -F: '/Operating System/ {sub(/^[ \t]+/, "", $2); print $2; exit}')"
    fi
    value_or_unknown "$value"
}

get_timezone() {
    local value=""
    if command_exists timedatectl; then
        value="$(timedatectl show -p Timezone --value 2>/dev/null || true)"
    fi
    if [ -z "$value" ] && [ -r /etc/timezone ]; then
        value="$(awk 'NF {print; exit}' /etc/timezone 2>/dev/null || true)"
    fi
    if [ -z "$value" ]; then
        value="$(date '+%Z' 2>/dev/null || true)"
    fi
    value_or_unknown "$value"
}

get_uptime() {
    local value=""
    if [ -r /proc/uptime ]; then
        value="$(awk '{
            seconds = int($1)
            days = int(seconds / 86400)
            hours = int((seconds % 86400) / 3600)
            minutes = int((seconds % 3600) / 60)
            if (days > 0) {
                printf "%d 天 %d 小时 %d 分钟", days, hours, minutes
            } else if (hours > 0) {
                printf "%d 小时 %d 分钟", hours, minutes
            } else {
                printf "%d 分钟", minutes
            }
        }' /proc/uptime 2>/dev/null || true)"
    fi
    if [ -z "$value" ]; then
        value="$(uptime -p 2>/dev/null || true)"
    fi
    value_or_unknown "$value"
}

get_cpu_model() {
    local value=""
    if [ -r /proc/cpuinfo ]; then
        value="$(awk -F: '
            /model name/ {sub(/^[ \t]+/, "", $2); print $2; exit}
            /Hardware/ {sub(/^[ \t]+/, "", $2); print $2; exit}
            /Processor/ {sub(/^[ \t]+/, "", $2); print $2; exit}
        ' /proc/cpuinfo 2>/dev/null || true)"
    fi
    value_or_unknown "$value"
}

get_cpu_cores() {
    local value=""
    if [ -r /proc/cpuinfo ]; then
        value="$(awk -F: '/^processor[ \t]*:/ {count++} END {if (count > 0) print count}' /proc/cpuinfo 2>/dev/null || true)"
    fi
    value_or_unknown "$value"
}

get_cpu_usage() {
    local first second
    if [ ! -r /proc/stat ]; then
        printf '%s' "$UNKNOWN"
        return
    fi

    first="$(awk '/^cpu / {for (i = 2; i <= NF; i++) printf "%s ", $i; print ""; exit}' /proc/stat 2>/dev/null || true)"
    sleep 0.35
    second="$(awk '/^cpu / {for (i = 2; i <= NF; i++) printf "%s ", $i; print ""; exit}' /proc/stat 2>/dev/null || true)"

    if [ -z "$first" ] || [ -z "$second" ]; then
        printf '%s' "$UNKNOWN"
        return
    fi

    awk -v first="$first" -v second="$second" 'BEGIN {
        split(first, a)
        split(second, b)
        idle1 = a[4] + a[5]
        idle2 = b[4] + b[5]
        total1 = 0
        total2 = 0
        for (i in a) total1 += a[i]
        for (i in b) total2 += b[i]
        total_delta = total2 - total1
        idle_delta = idle2 - idle1
        if (total_delta <= 0) {
            printf "未知"
        } else {
            printf "%.1f%%", (total_delta - idle_delta) * 100 / total_delta
        }
    }'
}

get_load_average() {
    local value=""
    if [ -r /proc/loadavg ]; then
        value="$(awk '{print $1 " " $2 " " $3}' /proc/loadavg 2>/dev/null || true)"
    fi
    value_or_unknown "$value"
}

print_system_info() {
    print_kv "主机名" "$(get_hostname)"
    print_kv "系统版本" "$(get_os_version)"
    print_kv "内核版本" "$(value_or_unknown "$(uname -r 2>/dev/null || true)")"
    print_kv "系统架构" "$(value_or_unknown "$(uname -m 2>/dev/null || true)")"
    print_kv "当前时间" "$(value_or_unknown "$(date '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null || true)")"
    print_kv "运行时间" "$(get_uptime)"
    print_kv "当前时区" "$(get_timezone)"
}

print_cpu_info() {
    print_kv "CPU 型号" "$(get_cpu_model)"
    print_kv "CPU 核心数" "$(get_cpu_cores)"
    print_kv "CPU 使用率" "$(get_cpu_usage)"
    print_kv "系统负载" "$(get_load_average)"
}

print_memory_info() {
    local total_h used_h available_h total_m used_m available_m usage

    if ! command_exists free; then
        print_kv "总内存" "$UNKNOWN"
        print_kv "已用内存" "$UNKNOWN"
        print_kv "可用内存" "$UNKNOWN"
        print_kv "使用率" "$UNKNOWN"
        return
    fi

    read -r total_h used_h available_h < <(free -h 2>/dev/null | awk '/^Mem:/ {print $2, $3, $7; exit}')
    read -r total_m used_m available_m < <(free -m 2>/dev/null | awk '/^Mem:/ {print $2, $3, $7; exit}')

    if [ -n "${total_m:-}" ] && [ "$total_m" -gt 0 ] 2>/dev/null; then
        usage="$(calc_percent "$used_m" "$total_m")"
    else
        usage="$UNKNOWN"
    fi

    print_kv "总内存" "$(value_or_unknown "${total_h:-}")"
    print_kv "已用内存" "$(value_or_unknown "${used_h:-}")"
    print_kv "可用内存" "$(value_or_unknown "${available_h:-}")"
    print_kv "使用率" "$usage"
}

print_swap_info() {
    local total_h used_h free_h total_m used_m free_m usage

    if ! command_exists free; then
        print_kv "状态" "$UNKNOWN"
        print_kv "总量" "$UNKNOWN"
        print_kv "已用" "$UNKNOWN"
        print_kv "可用" "$UNKNOWN"
        print_kv "使用率" "$UNKNOWN"
        return
    fi

    read -r total_h used_h free_h < <(free -h 2>/dev/null | awk '/^Swap:/ {print $2, $3, $4; exit}')
    read -r total_m used_m free_m < <(free -m 2>/dev/null | awk '/^Swap:/ {print $2, $3, $4; exit}')

    if [ -z "${total_m:-}" ] || [ "$total_m" -eq 0 ] 2>/dev/null; then
        print_kv "状态" "未开启 Swap"
        print_kv "总量" "0B"
        print_kv "已用" "0B"
        print_kv "可用" "0B"
        print_kv "使用率" "0%"
        return
    fi

    usage="$(calc_percent "$used_m" "$total_m")"
    print_kv "总量" "$(value_or_unknown "${total_h:-}")"
    print_kv "已用" "$(value_or_unknown "${used_h:-}")"
    print_kv "可用" "$(value_or_unknown "${free_h:-}")"
    print_kv "使用率" "$usage"
}

print_disk_info() {
    local total used available usage

    if ! command_exists df; then
        print_kv "根分区总量" "$UNKNOWN"
        print_kv "根分区已用" "$UNKNOWN"
        print_kv "根分区可用" "$UNKNOWN"
        print_kv "根分区使用率" "$UNKNOWN"
        print_kv "主要挂载点" "$UNKNOWN"
        return
    fi

    read -r total used available usage < <(df -hP / 2>/dev/null | awk 'NR == 2 {print $2, $3, $4, $5; exit}')

    print_kv "根分区总量" "$(value_or_unknown "${total:-}")"
    print_kv "根分区已用" "$(value_or_unknown "${used:-}")"
    print_kv "根分区可用" "$(value_or_unknown "${available:-}")"
    print_kv "根分区使用率" "$(value_or_unknown "${usage:-}")"
    printf "\n主要挂载点磁盘占用列表:\n"
    df -hPT -x tmpfs -x devtmpfs -x squashfs -x overlay 2>/dev/null | awk '
        NR == 1 {
            printf "%-24s %-10s %-8s %-8s %-8s %-6s %s\n", "文件系统", "类型", "总量", "已用", "可用", "使用率", "挂载点"
            next
        }
        {
            printf "%-24s %-10s %-8s %-8s %-8s %-6s %s\n", $1, $2, $3, $4, $5, $6, $7
        }
    '
}

print_user_info() {
    local current_user login_count login_list

    if command_exists id; then
        current_user="$(id -un 2>/dev/null || true)"
    else
        current_user="${USER:-}"
    fi

    if command_exists who; then
        login_count="$(who 2>/dev/null | awk '{if (!seen[$1]++) count++} END {print count + 0}')"
        login_list="$(who 2>/dev/null | awk '{if (!seen[$1]++) list = list ? list ", " $1 : $1} END {print list ? list : "无"}')"
    else
        login_count="$UNKNOWN"
        login_list="$UNKNOWN"
    fi

    print_kv "当前用户" "$(value_or_unknown "$current_user")"
    print_kv "登录用户数" "$(value_or_unknown "$login_count")"
    print_kv "登录用户列表" "$(value_or_unknown "$login_list")"
}

get_primary_ipv4() {
    local value=""
    if command_exists ip; then
        value="$(ip -4 route get 1.1.1.1 2>/dev/null | awk '{for (i = 1; i <= NF; i++) if ($i == "src") {print $(i + 1); exit}}' || true)"
        if [ -z "$value" ]; then
            value="$(ip -o -4 addr show scope global 2>/dev/null | awk '{split($4, a, "/"); print a[1]; exit}' || true)"
        fi
    fi
    value_or_unknown "$value"
}

get_primary_ipv6() {
    local value=""
    if command_exists ip; then
        value="$(ip -6 route get 2606:4700:4700::1111 2>/dev/null | awk '{for (i = 1; i <= NF; i++) if ($i == "src") {print $(i + 1); exit}}' || true)"
        if [ -z "$value" ]; then
            value="$(ip -o -6 addr show scope global 2>/dev/null | awk '{split($4, a, "/"); print a[1]; exit}' || true)"
        fi
    fi

    if [ -n "$value" ]; then
        printf '%s' "$value"
    else
        printf '未检测到'
    fi
}

get_public_ip() {
    local family="$1"
    local value=""

    if ! command_exists curl; then
        printf '未检测到（curl 未安装）'
        return
    fi

    if [ "$family" = "4" ]; then
        value="$(curl -4 -fsS --connect-timeout 2 --max-time 4 https://api.ipify.org 2>/dev/null | awk 'NF {gsub(/[[:space:]]/, ""); print; exit}' || true)"
        if [[ "$value" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
            printf '%s' "$value"
            return
        fi
    else
        value="$(curl -6 -fsS --connect-timeout 2 --max-time 4 https://api.ipify.org 2>/dev/null | awk 'NF {gsub(/[[:space:]]/, ""); print; exit}' || true)"
        if [[ "$value" == *:* && "$value" != *" "* ]]; then
            printf '%s' "$value"
            return
        fi
    fi

    printf '未检测到'
}

get_default_gateway() {
    local value=""
    if command_exists ip; then
        value="$(ip route show default 2>/dev/null | awk '{
            gateway = ""
            dev = ""
            for (i = 1; i <= NF; i++) {
                if ($i == "via") gateway = $(i + 1)
                if ($i == "dev") dev = $(i + 1)
            }
            if (gateway != "") {
                printf "%s%s\n", gateway, dev != "" ? " (" dev ")" : ""
                exit
            }
        }' || true)"
        if [ -z "$value" ]; then
            value="$(ip -6 route show default 2>/dev/null | awk '{
                gateway = ""
                dev = ""
                for (i = 1; i <= NF; i++) {
                    if ($i == "via") gateway = $(i + 1)
                    if ($i == "dev") dev = $(i + 1)
                }
                if (gateway != "") {
                    printf "%s%s\n", gateway, dev != "" ? " (" dev ")" : ""
                    exit
                }
            }' || true)"
        fi
    fi
    value_or_unknown "$value"
}

get_dns_servers() {
    local value=""
    if [ -r /etc/resolv.conf ]; then
        value="$(awk '
            /^nameserver[ \t]+/ {
                if (!seen[$2]++) list = list ? list ", " $2 : $2
            }
            END {print list}
        ' /etc/resolv.conf 2>/dev/null || true)"
    fi
    value_or_unknown "$value"
}

print_network_info() {
    print_kv "内网 IPv4" "$(get_primary_ipv4)"
    print_kv "内网 IPv6" "$(get_primary_ipv6)"
    print_kv "公网 IPv4" "$(get_public_ip 4)"
    print_kv "公网 IPv6" "$(get_public_ip 6)"
    print_kv "默认网关" "$(get_default_gateway)"
    print_kv "DNS" "$(get_dns_servers)"
}

show_help() {
    cat <<'EOF'
用法:
  vpsinfo

显示 Ubuntu/Debian VPS 的基础运行状态。
EOF
}

main() {
    case "${1:-}" in
        -h|--help)
            show_help
            return 0
            ;;
    esac

    printf "================ VPS 基础信息 ================\n\n"

    printf "[系统信息]\n"
    print_system_info
    printf "\n[CPU 信息]\n"
    print_cpu_info
    printf "\n[内存信息]\n"
    print_memory_info
    printf "\n[Swap 信息]\n"
    print_swap_info
    printf "\n[磁盘信息]\n"
    print_disk_info
    printf "\n[用户信息]\n"
    print_user_info
    printf "\n[网络信息]\n"
    print_network_info
}

main "$@"
